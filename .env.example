# ============ Backend (.env) ============
# Put secrets in `backend/.env` and/or repo-root `.env` (both are loaded; root overrides on duplicate keys).
# FastAPI: `cd backend` → `uvicorn app.main:app --reload --host 0.0.0.0 --port 8000`
# Tests: `cd backend` → `pip install -r requirements-dev.txt` → `pytest`

GROQ_API_KEY=
GEMINI_API_KEY=
# Optional overrides:
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-1.5-flash

# Optional for local dev: leave both empty → API uses SQLite at backend/.data/useformly_dev.sqlite3
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret: Supabase Dashboard → Project Settings → API → JWT Secret (for verifying browser sessions).
# Production: always set this so the API accepts real user sessions (never rely on X-Dev-User-Id in prod).
SUPABASE_JWT_SECRET=

# Comma-separated browser origins (production SPA URL + local dev)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Max AI form generations per Supabase-signed-in user per UTC day (0 = unlimited)
# DAILY_LLM_CREDIT_LIMIT=20

# ============ Frontend (copy to frontend/.env.local) ============
# Vite: `npm run dev` — empty VITE_API_URL uses dev proxy to localhost:8000

VITE_API_URL=
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# Only when API runs WITHOUT SUPABASE_JWT_SECRET (local dev): optional stable user id
# VITE_DEV_USER_ID=00000000-0000-0000-0000-000000000001

# ============ Supabase Auth (dashboard) ============
# Email + password and magic links are supported in the app. For sign-up without a confirmation email step:
#   Authentication → Providers → Email → turn OFF "Confirm email" (instant session after sign-up).
# Also set Site URL to your app origin (e.g. https://your-app.vercel.app) and add the same under
# Authentication → URL Configuration → Redirect URLs (plus http://localhost:5173 for local dev).

# ============ Database ============
# Apply SQL in supabase/migrations/001_initial.sql via Supabase SQL editor or CLI.

# ============ Free hosting (MVP) ============
# Vercel (frontend):
#   1. Project → Settings → General → Root Directory = "frontend" (this repo is a monorepo).
#   2. Framework Preset: Vite. Build: npm run build. Output: dist (default for Vite).
#   3. Environment Variables (Production + Preview): VITE_API_URL=https://YOUR-API-HOST
#      (no trailing slash). Required: the API is not served from Vercel static hosting.
#   4. vercel.json SPA rewrite sends non-file routes to index.html but excludes /api/* so POSTs are not
#      rewritten to index.html (which caused 405 Method Not Allowed).
#   5. If the project root is the repo (not "frontend"), use repo-root vercel.json or set Root Directory = frontend.
# Render (free API) — repo includes render.yaml:
#   1. dashboard.render.com → New → Blueprint → connect GitHub → select this repo.
#   2. Render creates Web Service "useformly-api" (plan free). Complete env var prompts.
#      If you create the Web Service manually: leave Root Directory empty (repo root), or set it to
#      "backend" — build/start commands in render.yaml support both (fixes ModuleNotFoundError: app).
#      If logs show Python 3.14+: set Environment PYTHON_VERSION=3.12.8 (or rely on repo runtime.txt).
#      Start Command must end up with cwd containing the `app` package (see render.yaml).
#   3. Copy the service URL (https://useformly-api.onrender.com) into Vercel as VITE_API_URL (no trailing slash).
#   4. Set CORS_ORIGINS to your frontend origin(s), e.g. https://your-app.vercel.app,http://localhost:5173
#   5. Use Supabase in production (set SUPABASE_* on Render). Ephemeral disk: do not rely on SQLite there.
# Free tier spins down when idle; first request after sleep can take ~30–60s. Health: GET /health
