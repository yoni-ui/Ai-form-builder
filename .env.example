# ============ Backend (copy to backend/.env) ============
# FastAPI: run from `backend/` with `uvicorn app.main:app --reload --host 0.0.0.0 --port 8000`

GROQ_API_KEY=
GEMINI_API_KEY=
# Optional overrides:
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-1.5-flash

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret: Supabase Dashboard → Project Settings → API → JWT Secret (for verifying browser sessions)
SUPABASE_JWT_SECRET=

# Comma-separated browser origins (production SPA URL + local dev)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============ Frontend (copy to frontend/.env.local) ============
# Vite: `npm run dev` — empty VITE_API_URL uses dev proxy to localhost:8000

VITE_API_URL=
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# Only when API runs WITHOUT SUPABASE_JWT_SECRET (local dev): optional stable user id
# VITE_DEV_USER_ID=00000000-0000-0000-0000-000000000001

# ============ Database ============
# Apply SQL in supabase/migrations/001_initial.sql via Supabase SQL editor or CLI.

# ============ Free hosting (MVP) ============
# - SPA: Vercel or Cloudflare Pages (build: frontend `npm run build`, output `frontend/dist`).
# - API: Render or Fly.io free tier (start: `uvicorn app.main:app --host 0.0.0.0 --port $PORT` from `backend/`).
# - Set frontend VITE_API_URL to the public API URL; set backend CORS_ORIGINS to the SPA origin.
# - Cold starts on free dynos: first request after idle may take several seconds.
